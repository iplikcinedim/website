# ─────────────────────────────────────────────────────
# .env.example — The Brush Art HS
#
# USAGE:
#   cp .env.example .env.local
#   Never commit .env.local to git
#
# For static sites without a build tool:
#   Replace placeholder strings in js/config.js directly.
#   For production, use a serverless proxy to keep keys off the client.
# ─────────────────────────────────────────────────────

# EmailJS (https://www.emailjs.com)
EMAILJS_PUBLIC_KEY=your_public_key_here
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_TEMPLATE_ID=template_xxxxxxx

# Formspree (https://formspree.io) — alternative to EmailJS
FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id

# Google Analytics (optional)
GA_MEASUREMENT_ID=G-XXXXXXXXXX
